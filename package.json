{
  "name": "vi-notes",
  "version": "1.0.0",
  "description": "Authenticity verification platform for human writing",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces",
    "build": "npm run build --workspaces",
